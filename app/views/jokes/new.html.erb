<div class="container mt-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-6">
      <h2 class="mb-4">Generate a Joke</h2>

      <%= simple_form_for(@joke) do |f| %>
        <%= f.input :keywords,
                    label: "Give the AI some context",
                    placeholder: "e.g., Software engineer, debugging, coffee...",
                    input_html: { class: "mb-3" } %>

        <%= f.submit "Make me laugh", class: "btn btn-primary w-100" %>
      <% end %>
    </div>
  </div>
</div>
