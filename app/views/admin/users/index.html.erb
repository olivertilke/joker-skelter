<div class="container mt-4 mb-5">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-11 col-xl-10">

      <!-- Admin Header -->
      <div class="admin-header mb-4">
        <h1 class="admin-title">
          <i class="fas fa-shield-alt me-2"></i> Admin Dashboard
        </h1>
        <p class="admin-subtitle">Manage your empire of degenerates.</p>
      </div>

      <!-- Stats Cards -->
      <div class="row g-3 mb-4">
        <div class="col-6 col-md-3">
          <div class="admin-stat-card">
            <div class="stat-icon"><i class="fas fa-users"></i></div>
            <div class="stat-number"><%= @total_users %></div>
            <div class="stat-label">Total Users</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="admin-stat-card">
            <div class="stat-icon"><i class="fas fa-user-plus"></i></div>
            <div class="stat-number"><%= @new_users_today %></div>
            <div class="stat-label">Signed Up Today</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="admin-stat-card">
            <div class="stat-icon"><i class="fas fa-laugh-squint"></i></div>
            <div class="stat-number"><%= @total_jokes %></div>
            <div class="stat-label">Total Jokes</div>
          </div>
        </div>
        <div class="col-6 col-md-3">
          <div class="admin-stat-card">
            <div class="stat-icon"><i class="fas fa-comments"></i></div>
            <div class="stat-number"><%= @total_chats %></div>
            <div class="stat-label">Total Chats</div>
          </div>
        </div>
      </div>

      <!-- Users Table -->
      <div class="admin-table-card">
        <div class="admin-table-header">
          <h5 class="mb-0"><i class="fas fa-list me-2"></i> All Users (<%= @total_users %>)</h5>
        </div>
        <div class="table-responsive">
          <table class="table admin-table mb-0">
            <thead>
              <tr>
                <th>#</th>
                <th>Email</th>
                <th>Jokes</th>
                <th>Chats</th>
                <th>Role</th>
                <th>Joined</th>
                <th class="text-end">Actions</th>
              </tr>
            </thead>
            <tbody>
              <% @users.each_with_index do |user, i| %>
                <tr>
                  <td class="text-muted"><%= user.id %></td>
                  <td>
                    <span class="user-email"><%= user.email %></span>
                    <% if user == current_user %>
                      <span class="badge bg-info ms-2">You</span>
                    <% end %>
                  </td>
                  <td><span class="badge bg-secondary"><%= user.jokes.count %></span></td>
                  <td><span class="badge bg-secondary"><%= user.chats.count %></span></td>
                  <td>
                    <% if user.admin? %>
                      <span class="badge admin-badge"><i class="fas fa-crown me-1"></i> Admin</span>
                    <% else %>
                      <span class="badge bg-dark">User</span>
                    <% end %>
                  </td>
                  <td class="text-muted"><%= user.created_at.strftime("%b %d, %Y") %></td>
                  <td class="text-end">
                    <% if user != current_user %>
                      <%= button_to admin_user_path(user),
                            method: :delete,
                            class: "btn btn-sm btn-outline-danger",
                            data: { turbo_confirm: "Are you sure you want to delete #{user.email}? This action is irreversible!" } do %>
                        <i class="fas fa-trash-alt"></i>
                      <% end %>
                    <% else %>
                      <span class="text-muted small">—</span>
                    <% end %>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>

    </div>
  </div>
</div>
