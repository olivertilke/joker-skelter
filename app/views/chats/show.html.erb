<div class="container mt-4 mb-5">
  <div class="row justify-content-center">
    <div class="col-12 col-lg-10 col-xl-8">

      <!-- Context Header -->
      <div class="card joke-context-card mb-4 rounded-4">
        <div class="card-body text-center p-4">
          <div class="text-uppercase small flex-shrink-0 mb-3" style="color: #A78BFA; font-weight: 700; letter-spacing: 1px;">
            <i class="fas fa-ghost me-1"></i> Discussing Joke
          </div>
          <p class="mb-0 fw-bold joke-text">"<%= @joke.content %>"</p>
        </div>
      </div>

      <!-- Chat Area -->
      <div class="chat-container rounded-4 mb-4">
        <% @chat.messages.each do |message| %>
          <div class="chat-message <%= message.role == 'user' ? 'user' : 'ai' %>">
            <span class="chat-role-label">
              <%= message.role == 'user' ? 'You' : 'Joker AI' %>
            </span>
            <div class="chat-bubble">
              <%= simple_format(message.content, class: "mb-0") %>
            </div>
          </div>
        <% end %>
      </div>

      <!-- Input Area -->
      <%= simple_form_for [@chat, @message] do |f| %>
        <div class="chat-input-wrapper d-flex align-items-center">
          <%= f.input_field :content, 
                            class: "form-control form-control-lg flex-grow-1", 
                            placeholder: "Tell the AI what to change...", 
                            autocomplete: "off" %>
          <button type="submit" class="btn btn-send shadow-sm ms-2">
            <i class="fas fa-paper-plane"></i>
          </button>
        </div>
      <% end %>

      <div class="text-center mt-4">
        <%= link_to joke_path(@joke), class: "btn btn-outline-secondary rounded-pill px-4" do %>
          <i class="fas fa-arrow-left me-2"></i> Vault
        <% end %>
      </div>
    </div>
  </div>
</div>
